{
  "destructive_verbs": [
    "delete",
    "remove",
    "update",
    "write",
    "edit",
    "patch",
    "create",
    "insert",
    "drop",
    "purchase",
    "pay",
    "exec",
    "deploy"
  ],
  "tool_rules": [
    {
      "code": "exec_confirmation",
      "title": "命令执行确认",
      "detail": "该操作将执行命令、脚本或程序，可能修改本地环境、安装依赖、访问网络或触发不可逆副作用。",
      "severity": "warning",
      "action": "confirm",
      "score": 0.9,
      "tool_names": ["exec", "shell", "terminal", "bash", "sh", "zsh", "command", "script", "run"],
      "param_keywords": ["rm ", "mv ", "cp ", "chmod", "chown", "sudo", "curl ", "wget ", "npm install", "pip install", "brew install", "git push", "deploy", "restart", "kill "]
    },
    {
      "code": "file_write_confirmation",
      "title": "文件写入或删除",
      "detail": "该操作会改写、创建、删除或覆盖文件内容，可能影响源码、配置、证书或运行环境。",
      "severity": "warning",
      "action": "confirm",
      "score": 0.9,
      "tool_names": ["write", "edit", "patch", "delete", "remove", "unlink", "save", "overwrite", "create_file"],
      "param_keywords": [".env", ".ssh", "authorized_keys", "config", "settings", "credential", "secret", "token", "private_key"]
